{
  "name": "alphaspec",
  "version": "0.2.0",
  "description": "Lightweight, opinionated SDD scaffolder for AI coding assistants",
  "type": "module",
  "bin": {
    "alphaspec": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
